<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Picshare.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="Picshare.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <DataTemplate x:Key="AlbumPhotoRowTemplate" x:DataType="vm:AlbumPhotoRowViewModel">
      <ItemsControl ItemsSource="{Binding Photos}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:AlbumPhotoViewModel">
            <Border Width="220"
                    Height="190"
                    Margin="0,0,12,12"
                    Background="White"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    CornerRadius="6"
                    Loaded="AlbumPhoto_Loaded"
                    Unloaded="AlbumPhoto_Unloaded">
              <Grid RowDefinitions="150,40">
                <Button Click="AlbumPhoto_Click"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        ClipToBounds="True"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch">
                  <Image Source="{Binding Image}"
                         Stretch="UniformToFill"
                         RenderTransformOrigin="50%,50%">
                    <Image.RenderTransform>
                      <RotateTransform Angle="{Binding RotationDegrees}"/>
                    </Image.RenderTransform>
                  </Image>
                </Button>
                <Border Width="72"
                        Height="54"
                        Margin="0,0,8,8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="#E627343B"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding HasDuplicateGroup}">
                  <Grid>
                    <Border Margin="8,4,0,0"
                            Background="#9AD9E5E8"
                            BorderBrush="#27343B"
                            BorderThickness="1"/>
                    <Border Margin="4,8,4,4"
                            Background="#D9FFFFFF"
                            BorderBrush="#27343B"
                            BorderThickness="1"
                            ClipToBounds="True">
                      <Image Source="{Binding DuplicateStackPhoto.Image}"
                             Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="{Binding DuplicateGroupCountText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <Border Width="22"
                            Height="22"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#1E8E3E"
                            BorderBrush="White"
                            BorderThickness="1"
                            IsVisible="{Binding IsBestMarkerVisible}">
                      <TextBlock Text="V"
                                 Foreground="White"
                                 FontSize="16"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                  </Grid>
                </Border>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MinWidth="38"
                        Height="32"
                        Margin="0,6,6,0"
                        Padding="8,4"
                        Click="AlbumPhotoSelection_Click"
                        Background="{Binding SelectionBackground}"
                        Foreground="{Binding SelectionForeground}"
                        BorderBrush="#27343B"
                        BorderThickness="1">
                  <TextBlock Text="{Binding SelectionGlyph}" FontWeight="SemiBold"/>
                </Button>
                <Border Grid.Row="1" Background="#F2F2EE" Padding="8">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#7B4B39" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </DataTemplate>

    <DataTemplate x:Key="AlbumPhotoGroupTemplate" x:DataType="vm:AlbumPhotoGroupViewModel">
      <StackPanel Spacing="8" Margin="0,0,0,12">
        <TextBlock Text="{Binding Header}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#27343B"/>
        <ItemsControl ItemsSource="{Binding Rows}"
                      ItemTemplate="{StaticResource AlbumPhotoRowTemplate}"/>
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="AlbumPhotoSourceRowTemplate" x:DataType="vm:AlbumPhotoSourceRowViewModel">
      <ItemsControl ItemsSource="{Binding Photos}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:AlbumPhotoSourceViewModel">
            <Button Click="AlbumPhotoSource_Click"
                    Padding="0"
                    Margin="0,0,8,8"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTip.Tip="{Binding FileName}">
              <Border Width="76"
                      Height="76"
                      Background="#EDF0ED"
                      BorderBrush="{Binding CardBorderBrush}"
                      BorderThickness="{Binding CardBorderThickness}"
                      CornerRadius="4"
                      ClipToBounds="True">
                <Grid RowDefinitions="*,22">
                  <TextBlock Text="IMG"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="#6C756F"
                             FontSize="12"
                             FontWeight="SemiBold"/>
                  <Border Grid.Row="1"
                          Background="#D9FFFFFF"
                          Padding="4,2">
                    <TextBlock Text="{Binding FileName}"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center"/>
                  </Border>
                </Grid>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </DataTemplate>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*,Auto" Background="#F7F7F4">
    <Border Grid.Row="0" Background="#27343B" Padding="20,16">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Spacing="3">
          <TextBlock Text="Picshare" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
          <TextBlock Text="Serverless photo albums on Google Drive" Foreground="#D9E5E8"/>
        </StackPanel>
        <TextBlock Grid.Column="1"
                   Text="{Binding Status}"
                   Foreground="#D9E5E8"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="420"
                   Margin="0,0,12,0"/>
        <Button Grid.Column="2"
                Command="{Binding ShowSettingsPanelCommand}"
                Padding="12,8"
                VerticalAlignment="Center">
          Settings
        </Button>
      </Grid>
    </Border>

    <TabControl Grid.Row="1" Margin="20">
      <TabItem Header="Create">
        <Grid>
          <ScrollViewer>
            <Grid ColumnDefinitions="440,*"
                  RowDefinitions="Auto,Auto">
            <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#D6D8D1" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,20,0">
              <StackPanel Spacing="12">
                <TextBlock Text="New album" FontSize="18" FontWeight="SemiBold"/>

                <StackPanel Spacing="5">
                  <TextBlock Text="Album type"/>
                  <ComboBox ItemsSource="{Binding AlbumTypes}"
                            SelectedItem="{Binding SelectedAlbumType}"
                            HorizontalAlignment="Stretch"
                            PlaceholderText="Choose album type">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:AlbumTypeOptionViewModel">
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding Title}"/>
                          <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#6C756F" TextWrapping="Wrap"/>
                        </StackPanel>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Spacing="12" IsVisible="{Binding IsAlbumSettingsVisible}">
                  <TextBlock Text="Album details" FontSize="15" FontWeight="SemiBold"/>

                  <StackPanel Spacing="5">
                    <TextBlock Text="Album name"/>
                    <TextBox Text="{Binding AlbumTitle}"/>
                  </StackPanel>

                  <StackPanel Spacing="5">
                    <TextBlock Text="Target nice pictures"/>
                    <NumericUpDown Value="{Binding TargetNicePhotoCount}"
                                   Minimum="0"
                                   Increment="1"
                                   FormatString="0"/>
                  </StackPanel>

                  <StackPanel Spacing="5">
                    <TextBlock Text="Photos"/>
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto">
                      <ListBox x:Name="AlbumPhotosList"
                               Grid.Row="0"
                               Grid.ColumnSpan="3"
                               ItemsSource="{Binding AlbumPhotoRows}"
                               SelectionMode="Single"
                               MinHeight="150"
                               MaxHeight="260"
                               ItemTemplate="{StaticResource AlbumPhotoSourceRowTemplate}"
                               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                          <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                          </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                      </ListBox>
                      <Button Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,8,8,0"
                              Padding="12,8"
                              Content="Add photos">
                        <Button.Flyout>
                          <Flyout>
                            <StackPanel Spacing="6" MinWidth="210">
                              <Button Click="ManualPhotoImport_Click"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Left"
                                      Content="Select files manually"/>
                              <Button Click="FolderDatePhotoImport_Click"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Left"
                                      Content="Select by folder and date"/>
                            </StackPanel>
                          </Flyout>
                        </Button.Flyout>
                      </Button>
                      <Button Grid.Row="1"
                              Grid.Column="2"
                              Click="RemoveSelectedAlbumPhotos_Click"
                              Margin="0,8,0,0"
                              Padding="12,8">
                        Remove selected
                      </Button>
                    </Grid>
                  </StackPanel>

                  <StackPanel Spacing="8" IsVisible="{Binding IsGoogleDriveAlbumSettingsVisible}">
                    <TextBlock Text="Google Drive" FontWeight="SemiBold"/>

                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding GoogleConnectionStatus}" VerticalAlignment="Center"/>
                      <Button Grid.Column="1"
                              Click="SignInGoogle_Click"
                              Padding="12,8">
                        Sign in
                      </Button>
                    </Grid>

                    <Border Background="#F2F2EE"
                            BorderBrush="#D6D8D1"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            IsVisible="{Binding IsGoogleSignInInstructionVisible}">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding GoogleSignInMessage}" TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                          <TextBox Text="{Binding GoogleSignInUrl}" IsReadOnly="True" Margin="0,0,8,0"/>
                          <Button Grid.Column="1"
                                  Click="OpenGoogleSignIn_Click"
                                  Padding="12,8"
                                  Margin="0,0,8,0">
                            Open Google
                          </Button>
                          <Button Grid.Column="2"
                                  Command="{Binding CancelGoogleSignInCommand}"
                                  Padding="12,8">
                            Cancel
                          </Button>
                        </Grid>
                      </StackPanel>
                    </Border>

                    <StackPanel Spacing="5">
                      <TextBlock Text="Album destination"/>
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding SelectedDriveFolderName}" IsReadOnly="True" Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Command="{Binding LoadDriveFoldersCommand}"
                                Padding="12,8">
                          Select
                        </Button>
                      </Grid>
                    </StackPanel>
                  </StackPanel>

                  <StackPanel Spacing="8" IsVisible="{Binding IsLocalAlbumSettingsVisible}">
                    <TextBlock Text="Local storage" FontWeight="SemiBold"/>
                    <StackPanel Spacing="5">
                      <TextBlock Text="Album destination"/>
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding SelectedLocalAlbumDestinationName}" IsReadOnly="True" Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Click="ChooseLocalAlbumDestination_Click"
                                Padding="12,8">
                          Select
                        </Button>
                      </Grid>
                    </StackPanel>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,Auto">
                    <Button Command="{Binding CreateAlbumCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="14,10"
                            Margin="0,0,8,0">
                      OK (upload)
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding CancelAlbumCreationCommand}"
                            Padding="14,10">
                      Cancel
                    </Button>
                  </Grid>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Background="White" BorderBrush="#D6D8D1" BorderThickness="1" CornerRadius="6" Padding="18" IsVisible="{Binding IsCreateResultVisible}">
              <StackPanel Spacing="12">
                <TextBlock Text="Album created" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="Send this link to friends so they can open the album." TextWrapping="Wrap"/>

                <StackPanel Spacing="5">
                  <TextBlock Text="Picshare link"/>
                  <TextBox Text="{Binding ShareLink}" IsReadOnly="True" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Spacing="5">
                  <TextBlock Text="Album location"/>
                  <TextBox Text="{Binding DriveFolderLink}" IsReadOnly="True" TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Border>
            </Grid>
          </ScrollViewer>

          <Grid Background="#80000000"
                IsVisible="{Binding IsDriveFolderPickerVisible}">
            <Border Background="White"
                    BorderBrush="#D6D8D1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18"
                    Margin="20"
                    MaxWidth="720"
                    MaxHeight="620"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
              <Grid RowDefinitions="Auto,Auto,*,Auto">
                <TextBlock Text="Select Google Drive folder" FontSize="18" FontWeight="SemiBold"/>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                  <Button Command="{Binding GoToParentDriveFolderCommand}"
                          Padding="12,8"
                          Margin="0,0,8,0">
                    Up
                  </Button>
                  <TextBox Grid.Column="1"
                           Text="{Binding CurrentDriveFolderName}"
                           IsReadOnly="True"
                           Margin="0,0,8,0"/>
                  <Button Grid.Column="2"
                          Command="{Binding ShowCreateDriveFolderDialogCommand}"
                          IsEnabled="{Binding CurrentDriveFolderCanBeUsed}"
                          Padding="12,8">
                    Create
                  </Button>
                </Grid>

                <Grid Grid.Row="2" RowDefinitions="*,Auto" Margin="0,12,0,0">
                  <ListBox ItemsSource="{Binding DriveItems}"
                           MinHeight="260"
                           MaxHeight="390"
                           SelectionMode="Single"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:DriveItemViewModel">
                        <Button Click="DriveItem_Click"
                                IsEnabled="{Binding CanOpen}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Padding="8"
                                Background="Transparent"
                                BorderThickness="0">
                          <Grid ColumnDefinitions="70,*">
                            <TextBlock Text="{Binding Icon}"
                                       Foreground="#27343B"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                              <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                              <TextBlock Text="{Binding Description}"
                                         FontSize="11"
                                         Foreground="#6C756F"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <Button Grid.Row="1"
                          Command="{Binding LoadMoreDriveItemsCommand}"
                          IsVisible="{Binding HasMoreDriveItems}"
                          HorizontalAlignment="Center"
                          Padding="12,8"
                          Margin="0,8,0,0">
                    Load more
                  </Button>
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,12,0,0">
                  <TextBlock Text="OK selects the current folder."
                             VerticalAlignment="Center"
                             Foreground="#6C756F"
                             TextWrapping="Wrap"/>
                  <Button Grid.Column="2"
                          Command="{Binding CancelDriveFolderPickerCommand}"
                          Padding="12,8"
                          Margin="0,0,8,0">
                    Cancel
                  </Button>
                  <Button Grid.Column="3"
                          Command="{Binding UseCurrentDriveFolderCommand}"
                          IsEnabled="{Binding CurrentDriveFolderCanBeUsed}"
                          Padding="12,8">
                    OK
                  </Button>
                </Grid>
              </Grid>
            </Border>
          </Grid>

          <Grid Background="#80000000"
                IsVisible="{Binding IsCreateDriveFolderDialogVisible}">
            <Border Background="White"
                    BorderBrush="#D6D8D1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18"
                    Margin="20"
                    MaxWidth="420"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
              <StackPanel Spacing="12">
                <TextBlock Text="Create folder" FontSize="18" FontWeight="SemiBold"/>
                <TextBox Text="{Binding NewDriveFolderName}"
                         Watermark="Folder name"/>
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <Button Grid.Column="1"
                          Command="{Binding CancelCreateDriveFolderCommand}"
                          Padding="12,8"
                          Margin="0,0,8,0">
                    Cancel
                  </Button>
                  <Button Grid.Column="2"
                          Command="{Binding CreateDriveFolderCommand}"
                          Padding="12,8">
                    Create
                  </Button>
                </Grid>
              </StackPanel>
            </Border>
          </Grid>

          <Grid Background="#80000000"
                IsVisible="{Binding IsFolderDateImportVisible}">
            <Border Background="White"
                    BorderBrush="#D6D8D1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18"
                    Margin="20"
                    MaxWidth="620"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
              <StackPanel Spacing="12">
                <TextBlock Text="Select photos by folder and date" FontSize="18" FontWeight="SemiBold"/>

                <StackPanel Spacing="5">
                  <TextBlock Text="Folders"/>
                  <TextBox Text="{Binding FolderDateImportSourceText}"
                           IsReadOnly="True"
                           TextWrapping="Wrap"
                           MinHeight="54"/>
                </StackPanel>

                <Grid ColumnDefinitions="*,Auto,Auto">
                  <DatePicker SelectedDate="{Binding ImportDate}" Margin="0,0,8,0"/>
                  <Button Grid.Column="1"
                          Command="{Binding ScanFolderDateImportCommand}"
                          Padding="12,8"
                          Margin="0,0,8,0">
                    Scan
                  </Button>
                  <Button Grid.Column="2"
                          Click="ChooseFolderDateImportFolders_Click"
                          Padding="12,8">
                    Choose folders
                  </Button>
                </Grid>

                <Border Height="1" Background="#D6D8D1"/>

                <StackPanel Spacing="8" IsVisible="{Binding IsImportCandidatesVisible}">
                  <TextBlock Text="Matching photos" FontWeight="SemiBold"/>
                  <ListBox x:Name="ImportCandidatesList"
                           ItemsSource="{Binding ImportCandidateRows}"
                           SelectionMode="Single"
                           MinHeight="180"
                           MaxHeight="260"
                           ItemTemplate="{StaticResource AlbumPhotoSourceRowTemplate}"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                  </ListBox>
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                    <Button Click="AddSelectedImportCandidates_Click" Padding="12,8" Margin="0,0,8,0">Add selected</Button>
                    <Button Grid.Column="1" Command="{Binding AddAllImportCandidatesCommand}" Padding="12,8">Add all</Button>
                    <Button Grid.Column="3" Command="{Binding ClearImportCandidatesCommand}" Padding="12,8">Clear</Button>
                  </Grid>
                </StackPanel>

                <Grid ColumnDefinitions="*,Auto">
                  <Button Grid.Column="1"
                          Command="{Binding CancelFolderDateImportCommand}"
                          Padding="12,8">
                    Cancel
                  </Button>
                </Grid>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </TabItem>

      <TabItem Header="Open">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="White" BorderBrush="#D6D8D1" BorderThickness="1" CornerRadius="6" Padding="18">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBox Text="{Binding OpenAlbumLink}" Watermark="Paste Picshare link or Google Drive manifest file link" Margin="0,0,12,0"/>
              <Button Grid.Column="1" Command="{Binding OpenAlbumCommand}" Padding="16,8">Open</Button>
              <Button Grid.Column="2"
                      IsEnabled="{Binding HasRecentAlbums}"
                      Padding="10,8"
                      Margin="8,0,0,0">
                Recent
                <Button.Flyout>
                  <MenuFlyout ItemsSource="{Binding RecentAlbums}">
                    <MenuFlyout.ItemTemplate>
                      <DataTemplate x:DataType="vm:RecentAlbumViewModel">
                        <MenuItem Header="{Binding DisplayText}"
                                  Click="RecentAlbum_Click"/>
                      </DataTemplate>
                    </MenuFlyout.ItemTemplate>
                  </MenuFlyout>
                </Button.Flyout>
              </Button>
            </Grid>
          </Border>

          <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,16,0,0">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,14">
                <TextBlock Text="{Binding CurrentAlbumTitle}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding CommitFeedbackStatus}"
                           IsVisible="{Binding IsStandardFeedbackActionsVisible}"
                           Foreground="#6C756F"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Button Grid.Column="2"
                        Command="{Binding CommitFeedbackCommand}"
                        IsVisible="{Binding IsStandardFeedbackActionsVisible}"
                        IsEnabled="{Binding CanCommitFeedback}"
                        Margin="0,0,8,0"
                        Padding="12,8">
                  Commit feedback
                </Button>
                <Button Grid.Column="3"
                        IsEnabled="{Binding CanUseAlbumMoreMenu}"
                        Padding="12,8">
                  More
                  <Button.Flyout>
                    <MenuFlyout>
                      <MenuItem Header="pass"
                                Command="{Binding PassFeedbackCommand}"
                                IsVisible="{Binding CanPassFeedback}"
                                IsEnabled="{Binding CanPassFeedback}"/>
                      <MenuItem Header="Download the album..."
                                Command="{Binding OpenAlbumDownloadDialogCommand}"
                                IsEnabled="{Binding CanUseAlbumMoreMenu}"/>
                    </MenuFlyout>
                  </Button.Flyout>
                </Button>
                <TextBlock Grid.Column="1"
                           Text="{Binding FinalizedFeedbackMessage}"
                           IsVisible="{Binding IsLeaveFeedbackVisible}"
                           Foreground="#6C756F"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="520"
                           Margin="0,0,10,0"/>
                <Button Grid.Column="2"
                        Command="{Binding LeaveFeedbackCommand}"
                        IsVisible="{Binding IsLeaveFeedbackVisible}"
                        IsEnabled="{Binding CanLeaveFeedback}"
                        Padding="12,8">
                  Leave
                </Button>
              </Grid>
              <TabControl x:Name="AlbumReviewTabs" Grid.Row="1" SelectionChanged="AlbumReviewTabs_SelectionChanged">
                <TabItem Header="{Binding UncategorizedTabHeader}" Tag="uncategorized">
                  <ListBox ItemsSource="{Binding UncategorizedPhotoGroups}"
                           Background="Transparent"
                           BorderThickness="0"
                           ItemTemplate="{StaticResource AlbumPhotoGroupTemplate}"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                  </ListBox>
                </TabItem>
                <TabItem Header="{Binding NiceTabHeader}" Tag="nice">
                  <ListBox ItemsSource="{Binding NicePhotoGroups}"
                           Background="Transparent"
                           BorderThickness="0"
                           ItemTemplate="{StaticResource AlbumPhotoGroupTemplate}"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                  </ListBox>
                </TabItem>
                <TabItem Header="{Binding OkTabHeader}" Tag="ok">
                  <ListBox ItemsSource="{Binding OkPhotoGroups}"
                           Background="Transparent"
                           BorderThickness="0"
                           ItemTemplate="{StaticResource AlbumPhotoGroupTemplate}"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                  </ListBox>
                </TabItem>
                <TabItem Header="{Binding TrashTabHeader}" Tag="trash">
                  <ListBox ItemsSource="{Binding TrashPhotoGroups}"
                           Background="Transparent"
                           BorderThickness="0"
                           ItemTemplate="{StaticResource AlbumPhotoGroupTemplate}"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                  </ListBox>
                </TabItem>
                <TabItem Header="{Binding UnresolvedDuplicatesTabHeader}"
                         Tag="unresolved-duplicates"
                         IsVisible="{Binding HasUnresolvedDuplicatePhotos}">
                  <ListBox ItemsSource="{Binding UnresolvedDuplicatePhotoGroups}"
                           Background="Transparent"
                           BorderThickness="0"
                           ItemTemplate="{StaticResource AlbumPhotoGroupTemplate}"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                  </ListBox>
                </TabItem>
                <TabItem Header="{Binding FlowTabHeader}" IsVisible="{Binding IsAuthorFlowVisible}" Tag="flow">
                  <ScrollViewer>
                    <StackPanel Spacing="16">
                      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                        <TextBlock Text="{Binding FlowStatus}"
                                   Foreground="#6C756F"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Command="{Binding CollectFeedbackCommand}"
                                IsVisible="{Binding IsCollectFeedbackVisible}"
                                IsEnabled="{Binding CanCollectFeedback}"
                                Margin="0,0,8,0"
                                Padding="12,8">
                          Collect the feedback
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding StartNextRoundCommand}"
                                IsVisible="{Binding CanStartNextRound}"
                                IsEnabled="{Binding CanStartNextRound}"
                                Margin="0,0,8,0"
                                Padding="12,8">
                          Next round
                        </Button>
                        <Button Grid.Column="3"
                                Command="{Binding FinalizeFeedbackCommand}"
                                IsVisible="{Binding CanFinalizeFeedback}"
                                IsEnabled="{Binding CanFinalizeFeedback}"
                                Margin="0,0,8,0"
                                Padding="12,8">
                          Finalize
                        </Button>
                        <Button Grid.Column="4"
                                Command="{Binding DeleteAlbumCommand}"
                                IsVisible="{Binding CanDeleteAlbum}"
                                IsEnabled="{Binding CanDeleteAlbum}"
                                Background="#B42318"
                                Foreground="White"
                                BorderBrush="#7A271A"
                                Padding="12,8">
                          Delete the album
                        </Button>
                      </Grid>
                      <StackPanel Spacing="6" IsVisible="{Binding IsRegularFlowVisible}">
                        <TextBlock Text="{Binding CommittedReviewersHeader}" FontWeight="SemiBold"/>
                        <ListBox ItemsSource="{Binding CommittedReviewers}"
                                 Background="Transparent"
                                 BorderThickness="0">
                          <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReviewerFeedbackFlowItemViewModel">
                              <Border Background="White"
                                      BorderBrush="#D6D8D1"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="12"
                                      Margin="0,0,0,8">
                                <StackPanel Spacing="2">
                                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#6C756F"/>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </StackPanel>
                      <StackPanel Spacing="6" IsVisible="{Binding IsRegularFlowVisible}">
                        <TextBlock Text="{Binding PassedReviewersHeader}" FontWeight="SemiBold"/>
                        <ListBox ItemsSource="{Binding PassedReviewers}"
                                 Background="Transparent"
                                 BorderThickness="0">
                          <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReviewerFeedbackFlowItemViewModel">
                              <Border Background="White"
                                      BorderBrush="#D6D8D1"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="12"
                                      Margin="0,0,0,8">
                                <StackPanel Spacing="2">
                                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#6C756F"/>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </StackPanel>
                      <StackPanel Spacing="6" IsVisible="{Binding IsFinalizedFlowVisible}">
                        <TextBlock Text="{Binding LeftReviewersHeader}" FontWeight="SemiBold"/>
                        <ListBox ItemsSource="{Binding LeftReviewers}"
                                 Background="Transparent"
                                 BorderThickness="0">
                          <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReviewerFeedbackFlowItemViewModel">
                              <Border Background="White"
                                      BorderBrush="#D6D8D1"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="12"
                                      Margin="0,0,0,8">
                                <StackPanel Spacing="2">
                                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#6C756F"/>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </StackPanel>
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding InProgressReviewersHeader}" FontWeight="SemiBold"/>
                        <ListBox ItemsSource="{Binding InProgressReviewers}"
                                 Background="Transparent"
                                 BorderThickness="0">
                          <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReviewerFeedbackFlowItemViewModel">
                              <Border Background="White"
                                      BorderBrush="#D6D8D1"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="12"
                                      Margin="0,0,0,8">
                                <StackPanel Spacing="2">
                                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#6C756F"/>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </StackPanel>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>
              </TabControl>
              <Border Grid.Row="1"
                      Background="#EE27343B"
                      BorderBrush="#99FFFFFF"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10"
                      Margin="12"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom"
                      IsVisible="{Binding IsBulkPhotoActionPanelVisible}">
                <WrapPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding BulkSelectionStatus}"
                             Foreground="White"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"/>
                  <Button Padding="14,10"
                          Margin="0,0,8,0"
                          Command="{Binding MarkSelectedPhotosUncategorizedCommand}"
                          IsVisible="{Binding ShouldShowSelectedPhotosUncategorizedAction}"
                          IsEnabled="{Binding CanMarkSelectedPhotosUncategorized}"
                          Background="White"
                          Foreground="Black"
                          BorderBrush="Black"
                          BorderThickness="2">
                    <Grid>
                      <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                      <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                      <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                      <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                      <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="Black"/>
                    </Grid>
                  </Button>
                  <Button Padding="14,10"
                          Margin="0,0,8,0"
                          Command="{Binding MarkSelectedPhotosNiceCommand}"
                          IsVisible="{Binding ShouldShowSelectedPhotosNiceAction}"
                          IsEnabled="{Binding CanMarkSelectedPhotosNice}"
                          Background="White"
                          Foreground="Black"
                          BorderBrush="Black"
                          BorderThickness="2">
                    <Grid>
                      <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                      <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                      <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                      <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                      <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="Black"/>
                    </Grid>
                  </Button>
                  <Button Padding="14,10"
                          Margin="0,0,8,0"
                          Command="{Binding MarkSelectedPhotosOkCommand}"
                          IsVisible="{Binding ShouldShowSelectedPhotosOkAction}"
                          IsEnabled="{Binding CanMarkSelectedPhotosOk}"
                          Background="White"
                          Foreground="Black"
                          BorderBrush="Black"
                          BorderThickness="2">
                    <Grid>
                      <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                      <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                      <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                      <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                      <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="Black"/>
                    </Grid>
                  </Button>
                  <Button Padding="14,10"
                          Margin="0,0,8,0"
                          Background="White"
                          Foreground="Black"
                          BorderBrush="Black"
                          BorderThickness="2">
                    <Grid>
                      <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                      <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                      <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                      <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                      <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="Black"/>
                    </Grid>
                    <Button.Flyout>
                      <MenuFlyout>
                        <MenuItem Header="Rotate left"
                                  Command="{Binding RotateSelectedPhotosLeftCommand}"
                                  IsEnabled="{Binding CanRotateSelectedPhotos}"/>
                        <MenuItem Header="Rotate right"
                                  Command="{Binding RotateSelectedPhotosRightCommand}"
                                  IsEnabled="{Binding CanRotateSelectedPhotos}"/>
                        <MenuItem Header="Mark as duplicates"
                                  Command="{Binding MarkSelectedPhotosAsDuplicatesCommand}"
                                  IsEnabled="{Binding CanMarkSelectedPhotosAsDuplicates}"/>
                        <MenuItem Header="Trash"
                                  Command="{Binding MarkSelectedPhotosTrashCommand}"
                                  IsVisible="{Binding CanShowSelectedPhotosTrashAction}"
                                  IsEnabled="{Binding CanMarkSelectedPhotosTrash}"/>
                        <MenuItem Header="Download..."
                                  Click="DownloadSelectedPhotos_Click"
                                  IsEnabled="{Binding CanDownloadSelectedPhotos}"/>
                        <MenuItem Header="Download as archive..."
                                  Click="DownloadSelectedPhotosArchive_Click"
                                  IsEnabled="{Binding CanDownloadSelectedPhotos}"/>
                      </MenuFlyout>
                    </Button.Flyout>
                  </Button>
                  <Button Command="{Binding ClearSelectedPhotosCommand}"
                          Width="44"
                          Height="44"
                          Padding="0"
                          Background="#33000000"
                          BorderBrush="#99FFFFFF"
                          BorderThickness="1"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center">
                    <Grid Width="28" Height="28">
                      <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="Black" Margin="-1,-1,0,0"/>
                      <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="Black" Margin="1,-1,0,0"/>
                      <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="Black" Margin="-1,1,0,0"/>
                      <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="Black" Margin="1,1,0,0"/>
                      <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    </Grid>
                  </Button>
                </WrapPanel>
              </Border>
          </Grid>
        </Grid>
      </TabItem>
    </TabControl>

    <ProgressBar Grid.Row="2"
                 IsIndeterminate="{Binding IsBusy}"
                 Height="3"
                 Minimum="0"
                 Maximum="1"
                 Value="0"/>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsSettingsPanelVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="680"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"/>
          <StackPanel Spacing="5">
            <TextBlock Text="Anonymous reviewer name" FontWeight="SemiBold"/>
            <TextBox Text="{Binding AnonymousReviewerName}"
                     Watermark="Name shown in local album flow lists"/>
          </StackPanel>
          <StackPanel Spacing="5">
            <TextBlock Text="Maximum parallel operations" FontWeight="SemiBold"/>
            <NumericUpDown Value="{Binding MaximumParallelism}"
                           Minimum="1"
                           Maximum="64"
                           Increment="1"/>
          </StackPanel>
          <StackPanel Spacing="5">
            <TextBlock Text="Default download directories" FontWeight="SemiBold"/>
            <Grid ColumnDefinitions="150,*,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
              <TextBlock Text="Picture" VerticalAlignment="Center" Margin="0,0,8,8"/>
              <TextBox Grid.Column="1" Text="{Binding PictureDefaultDownloadDirectoryPath}" Margin="0,0,8,8"/>
              <Button Grid.Column="2" Click="ChoosePictureDefaultDownloadDirectory_Click" Padding="12,8" Margin="0,0,8,8">Select</Button>
              <Button Grid.Column="3" Command="{Binding SetPictureDefaultDownloadDirectoryToDefaultCommand}" Padding="12,8" Margin="0,0,0,8">Set to default</Button>

              <TextBlock Grid.Row="1" Text="Uncategorized" VerticalAlignment="Center" Margin="0,0,8,8"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding UncategorizedDefaultDownloadDirectoryPath}" Margin="0,0,8,8"/>
              <Button Grid.Row="1" Grid.Column="2" Click="ChooseUncategorizedDefaultDownloadDirectory_Click" Padding="12,8" Margin="0,0,8,8">Select</Button>
              <Button Grid.Row="1" Grid.Column="3" Command="{Binding SetUncategorizedDefaultDownloadDirectoryToDefaultCommand}" Padding="12,8" Margin="0,0,0,8">Set to default</Button>

              <TextBlock Grid.Row="2" Text="Nice" VerticalAlignment="Center" Margin="0,0,8,8"/>
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NiceDefaultDownloadDirectoryPath}" Margin="0,0,8,8"/>
              <Button Grid.Row="2" Grid.Column="2" Click="ChooseNiceDefaultDownloadDirectory_Click" Padding="12,8" Margin="0,0,8,8">Select</Button>
              <Button Grid.Row="2" Grid.Column="3" Command="{Binding SetNiceDefaultDownloadDirectoryToDefaultCommand}" Padding="12,8" Margin="0,0,0,8">Set to default</Button>

              <TextBlock Grid.Row="3" Text="Ok" VerticalAlignment="Center" Margin="0,0,8,8"/>
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding OkDefaultDownloadDirectoryPath}" Margin="0,0,8,8"/>
              <Button Grid.Row="3" Grid.Column="2" Click="ChooseOkDefaultDownloadDirectory_Click" Padding="12,8" Margin="0,0,8,8">Select</Button>
              <Button Grid.Row="3" Grid.Column="3" Command="{Binding SetOkDefaultDownloadDirectoryToDefaultCommand}" Padding="12,8" Margin="0,0,0,8">Set to default</Button>

              <TextBlock Grid.Row="4" Text="Trash" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding TrashDefaultDownloadDirectoryPath}" Margin="0,0,8,0"/>
              <Button Grid.Row="4" Grid.Column="2" Click="ChooseTrashDefaultDownloadDirectory_Click" Padding="12,8" Margin="0,0,8,0">Select</Button>
              <Button Grid.Row="4" Grid.Column="3" Command="{Binding SetTrashDefaultDownloadDirectoryToDefaultCommand}" Padding="12,8">Set to default</Button>
            </Grid>
          </StackPanel>
          <Border Height="1" Background="#D6D8D1"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Downloaded thumbnails and full images"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="#6C756F"/>
            <Button Grid.Column="1"
                    Command="{Binding ClearImageCacheCommand}"
                    Padding="12,8">
              Clear cache
            </Button>
          </Grid>
          <Border Height="1" Background="#D6D8D1"/>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <StackPanel Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Google authorization" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding GoogleConnectionStatus}"
                         Foreground="#6C756F"
                         FontSize="12"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Click="SettingsSignInGoogle_Click"
                    Padding="12,8"
                    Margin="0,0,8,0">
              Sign in
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ClearGoogleAuthorizationCommand}"
                    Padding="12,8">
              Sign out
            </Button>
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CloseSettingsPanelCommand}"
                    Padding="12,8">
              Close
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsGoogleAuthorizationRequired}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="460"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Google authorization required" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding GoogleAuthorizationMessage}" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelGoogleAuthorizationCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              Cancel
            </Button>
            <Button Grid.Column="2"
                    Click="OpenAlbumSignInGoogle_Click"
                    Padding="12,8">
              Sign in with Google
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsAlbumDownloadDialogVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="780"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <Grid RowDefinitions="Auto,*,Auto" MaxHeight="560">
          <TextBlock Text="Download album" FontSize="18" FontWeight="SemiBold"/>
          <ScrollViewer Grid.Row="1" Margin="0,12,0,12">
            <ItemsControl ItemsSource="{Binding AlbumDownloadCategories}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AlbumDownloadCategoryViewModel">
                  <Border BorderBrush="#D6D8D1"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10"
                          Margin="0,0,0,8">
                    <Grid ColumnDefinitions="150,170,*,Auto">
                      <TextBlock Text="{Binding Header}"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"/>
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding ModeOptions}"
                                SelectedItem="{Binding SelectedMode}"
                                Margin="0,0,10,0">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:AlbumDownloadModeViewModel">
                            <TextBlock Text="{Binding Name}"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <TextBox Grid.Column="2"
                               Text="{Binding DestinationDirectoryPath}"
                               IsEnabled="{Binding IsDestinationDirectoryEnabled}"
                               Watermark="Destination directory"
                               Margin="0,0,10,0"/>
                      <Button Grid.Column="3"
                              Click="ChooseAlbumDownloadCategoryDestination_Click"
                              IsEnabled="{Binding IsDestinationDirectoryEnabled}"
                              Padding="12,8">
                        Select
                      </Button>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelAlbumDownloadDialogCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              Cancel
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding DownloadAlbumCommand}"
                    Padding="12,8">
              Download
            </Button>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsAlbumDownloadProgressVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="520"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Downloading album" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding AlbumDownloadProgressMessage}" TextWrapping="Wrap"/>
          <ProgressBar Minimum="0"
                       Maximum="{Binding AlbumDownloadProgressMaximum}"
                       Value="{Binding AlbumDownloadProgressValue}"
                       Height="10"/>
          <Grid ColumnDefinitions="*,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelAlbumDownloadProgressCommand}"
                    Padding="12,8">
              Cancel
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsAlbumCreationProgressVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="520"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Creating album" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding AlbumCreationProgressMessage}" TextWrapping="Wrap"/>
          <ProgressBar Minimum="0"
                       Maximum="{Binding AlbumCreationProgressMaximum}"
                       Value="{Binding AlbumCreationProgressValue}"
                       Height="10"/>
          <Grid ColumnDefinitions="*,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelAlbumCreationProgressCommand}"
                    Padding="12,8">
              Cancel
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#99000000"
          IsVisible="{Binding IsClearAlbumDestinationConfirmationVisible}">
      <Border Background="White"
              BorderBrush="#B42318"
              BorderThickness="2"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="520"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <Grid ColumnDefinitions="64,*" RowDefinitions="Auto,Auto,Auto">
          <Border Grid.RowSpan="3"
                  Width="48"
                  Height="48"
                  CornerRadius="24"
                  Background="#FEE4E2"
                  BorderBrush="#B42318"
                  BorderThickness="2"
                  VerticalAlignment="Top">
            <TextBlock Text="X"
                       Foreground="#B42318"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <TextBlock Grid.Column="1"
                     Text="Clear destination"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#7A271A"/>
          <TextBlock Grid.Row="1"
                     Grid.Column="1"
                     Text="{Binding ClearAlbumDestinationConfirmationMessage}"
                     TextWrapping="Wrap"
                     Margin="0,8,0,14"/>
          <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelClearAlbumDestinationCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              No
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ConfirmClearAlbumDestinationCommand}"
                    Background="#B42318"
                    Foreground="White"
                    BorderBrush="#7A271A"
                    Padding="12,8">
              Yes, clear and upload
            </Button>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsAlbumDeletionProgressVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="520"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Deleting album" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding AlbumDeletionProgressMessage}" TextWrapping="Wrap"/>
          <ProgressBar Minimum="0"
                       Maximum="{Binding AlbumDeletionProgressMaximum}"
                       Value="{Binding AlbumDeletionProgressValue}"
                       Height="10"/>
          <Grid ColumnDefinitions="*,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelAlbumDeletionProgressCommand}"
                    Padding="12,8">
              Cancel
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#99000000"
          IsVisible="{Binding IsCancelAlbumDeletionConfirmationVisible}">
      <Border Background="White"
              BorderBrush="#B42318"
              BorderThickness="2"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="520"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Stop deletion" FontSize="18" FontWeight="SemiBold" Foreground="#7A271A"/>
          <TextBlock Text="{Binding CancelAlbumDeletionConfirmationMessage}" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding KeepAlbumDeletionRunningCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              No
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ForceCancelAlbumDeletionCommand}"
                    Background="#B42318"
                    Foreground="White"
                    BorderBrush="#7A271A"
                    Padding="12,8">
              Yes, stop
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsFeedbackConflictNoticeVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="460"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Feedback updated" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding FeedbackConflictMessage}" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto">
            <Button Grid.Column="1"
                    Command="{Binding DismissFeedbackConflictNoticeCommand}"
                    Padding="12,8">
              OK
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsCommitConfirmationVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="460"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Commit feedback" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding CommitConfirmationMessage}" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelCommitFeedbackCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              No
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ConfirmCommitFeedbackCommand}"
                    Padding="12,8">
              Yes
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsPassConfirmationVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="460"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Pass on feedback" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding PassConfirmationMessage}" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelPassFeedbackCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              No
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ConfirmPassFeedbackCommand}"
                    Padding="12,8">
              Yes
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsCollectFeedbackConfirmationVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="460"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Collect feedback" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding CollectFeedbackConfirmationMessage}" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelCollectFeedbackCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              No
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ConfirmCollectFeedbackCommand}"
                    Padding="12,8">
              Yes
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsFinalizeConfirmationVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="460"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Finalize album" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding FinalizeConfirmationMessage}" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelFinalizeFeedbackCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              No
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ConfirmFinalizeFeedbackCommand}"
                    Padding="12,8">
              Yes
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#99000000"
          IsVisible="{Binding IsDeleteAlbumConfirmationVisible}">
      <Border Background="White"
              BorderBrush="#B42318"
              BorderThickness="2"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="520"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <Grid ColumnDefinitions="64,*" RowDefinitions="Auto,Auto,Auto">
          <Border Grid.RowSpan="3"
                  Width="48"
                  Height="48"
                  CornerRadius="24"
                  Background="#FEE4E2"
                  BorderBrush="#B42318"
                  BorderThickness="2"
                  VerticalAlignment="Top">
            <TextBlock Text="X"
                       Foreground="#B42318"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <TextBlock Grid.Column="1"
                     Text="Delete album"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#7A271A"/>
          <TextBlock Grid.Row="1"
                     Grid.Column="1"
                     Text="{Binding DeleteAlbumConfirmationMessage}"
                     TextWrapping="Wrap"
                     Margin="0,8,0,14"/>
          <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelDeleteAlbumCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              No
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ConfirmDeleteAlbumCommand}"
                    Background="#B42318"
                    Foreground="White"
                    BorderBrush="#7A271A"
                    Padding="12,8">
              Yes, delete
            </Button>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="{Binding IsLeaveConfirmationVisible}">
      <Border Background="White"
              BorderBrush="#D6D8D1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="18"
              Margin="20"
              MaxWidth="460"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Leave album" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding LeaveConfirmationMessage}" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CancelLeaveFeedbackCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0">
              No
            </Button>
            <Button Grid.Column="2"
                    Command="{Binding ConfirmLeaveFeedbackCommand}"
                    Padding="12,8">
              Yes
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="3"
          Background="#F8000000"
          IsVisible="{Binding IsPhotoViewerVisible}">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Background="#CC000000"
                Padding="14,10">
          <Grid ColumnDefinitions="44,*,Auto">
            <StackPanel Grid.Column="1"
                        Spacing="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="520">
              <TextBlock Text="{Binding PhotoViewerTitle}"
                         Foreground="White"
                         FontSize="16"
                         FontWeight="SemiBold"
                         TextAlignment="Center"
                         TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="{Binding PhotoViewerStatus}"
                         Foreground="#D9E5E8"
                         FontSize="12"
                         TextAlignment="Center"
                         TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          <Button Grid.Column="2"
                  Command="{Binding ClosePhotoViewerCommand}"
                  Width="44"
                  Height="44"
                  Padding="0"
                  Background="#33000000"
                  BorderBrush="#99FFFFFF"
                  BorderThickness="1"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center">
            <Grid Width="28" Height="28">
              <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="Black" Margin="-1,-1,0,0"/>
              <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="Black" Margin="1,-1,0,0"/>
              <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="Black" Margin="-1,1,0,0"/>
              <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="Black" Margin="1,1,0,0"/>
              <TextBlock Text="X" FontSize="28" FontWeight="Bold" Foreground="White"/>
            </Grid>
          </Button>
          </Grid>
        </Border>

        <Border x:Name="PhotoViewerViewport"
                Grid.Row="1"
                Padding="12"
                PointerPressed="PhotoViewer_PointerPressed"
                PointerMoved="PhotoViewer_PointerMoved"
                PointerReleased="PhotoViewer_PointerReleased"
                PointerWheelChanged="PhotoViewer_PointerWheelChanged">
          <Grid>
            <ScrollViewer x:Name="PhotoViewerScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <Image x:Name="PhotoViewerImageControl"
                     Source="{Binding PhotoViewerImage}"
                     Stretch="Uniform"
                     RenderTransformOrigin="50%,50%"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Image.RenderTransform>
                  <RotateTransform Angle="{Binding PhotoViewerRotationDegrees}"/>
                </Image.RenderTransform>
              </Image>
            </ScrollViewer>
            <Border Background="#99000000"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    IsVisible="{Binding IsPhotoViewerDuplicateStripVisible}">
              <CheckBox Command="{Binding ToggleCurrentPhotoBestInDuplicateGroupCommand}"
                        IsChecked="{Binding IsCurrentPhotoBestInDuplicateGroup, Mode=OneWay}"
                        Foreground="White"
                        FontWeight="SemiBold">
                Best in the group
              </CheckBox>
            </Border>
            <Border Background="#99000000"
                    CornerRadius="6"
                    Padding="8"
                    Margin="0,0,0,92"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    IsVisible="{Binding IsPhotoViewerDuplicateStripVisible}">
              <ItemsControl ItemsSource="{Binding PhotoViewerDuplicatePhotos}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:AlbumPhotoViewModel">
                    <Button Width="68"
                            Height="52"
                            Margin="0,0,6,0"
                            Padding="0"
                            Click="DuplicatePhotoViewerItem_Click"
                            BorderBrush="{Binding CardBorderBrush}"
                            BorderThickness="{Binding CardBorderThickness}"
                            ClipToBounds="True">
                      <Grid>
                        <Image Source="{Binding Image}"
                               Stretch="UniformToFill"
                               RenderTransformOrigin="50%,50%">
                          <Image.RenderTransform>
                            <RotateTransform Angle="{Binding RotationDegrees}"/>
                          </Image.RenderTransform>
                        </Image>
                        <Border Width="22"
                                Height="22"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="#1E8E3E"
                                BorderBrush="White"
                                BorderThickness="1"
                                IsVisible="{Binding IsBestMarkerVisible}">
                          <TextBlock Text="V"
                                     Foreground="White"
                                     FontSize="16"
                                     FontWeight="Bold"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Border>
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>
            <Border Background="#99000000"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,0,0,18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    IsVisible="{Binding IsPhotoViewerActionsVisible}">
              <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                <Button Padding="14,10"
                        Margin="0,0,8,0"
                        Command="{Binding ShowPreviousPhotoInCategoryCommand}"
                        IsEnabled="{Binding CanNavigatePhotoViewerCategory}"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="Black"
                        BorderThickness="2">
                  <Grid>
                    <TextBlock Text="&lt;" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                    <TextBlock Text="&lt;" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                    <TextBlock Text="&lt;" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                    <TextBlock Text="&lt;" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                    <TextBlock Text="&lt;" FontWeight="SemiBold" Foreground="Black"/>
                  </Grid>
                </Button>
                <Button Grid.Column="1"
                        Padding="14,10"
                        Margin="0,0,8,0"
                        Command="{Binding MarkCurrentPhotoUncategorizedCommand}"
                        IsVisible="{Binding ShouldShowCurrentPhotoUncategorizedAction}"
                        IsEnabled="{Binding CanMarkCurrentPhotoUncategorized}"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="Black"
                        BorderThickness="2">
                  <Grid>
                    <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                    <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                    <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                    <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                    <TextBlock Text="uncategorized 👻" FontWeight="SemiBold" Foreground="Black"/>
                  </Grid>
                </Button>
                <Button Grid.Column="2"
                        Padding="14,10"
                        Margin="0,0,8,0"
                        Command="{Binding MarkCurrentPhotoNiceCommand}"
                        IsVisible="{Binding ShouldShowCurrentPhotoNiceAction}"
                        IsEnabled="{Binding CanMarkCurrentPhotoNice}"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="Black"
                        BorderThickness="2">
                  <Grid>
                    <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                    <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                    <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                    <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                    <TextBlock Text="nice 😍" FontWeight="SemiBold" Foreground="Black"/>
                  </Grid>
                </Button>
                <Button Grid.Column="3"
                        Padding="14,10"
                        Margin="0,0,8,0"
                        Command="{Binding MarkCurrentPhotoOkCommand}"
                        IsVisible="{Binding ShouldShowCurrentPhotoOkAction}"
                        IsEnabled="{Binding CanMarkCurrentPhotoOk}"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="Black"
                        BorderThickness="2">
                  <Grid>
                    <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                    <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                    <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                    <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                    <TextBlock Text="ok 🗿" FontWeight="SemiBold" Foreground="Black"/>
                  </Grid>
                </Button>
                <Button Grid.Column="4"
                        Padding="14,10"
                        Margin="0,0,8,0"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="Black"
                        BorderThickness="2">
                  <Grid>
                    <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                    <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                    <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                    <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                    <TextBlock Text="more... ⚙" FontWeight="SemiBold" Foreground="Black"/>
                  </Grid>
                  <Button.Flyout>
                    <MenuFlyout>
                      <MenuItem Header="Rotate left"
                                Command="{Binding RotateCurrentPhotoLeftCommand}"
                                IsEnabled="{Binding CanDownloadCurrentPhoto}"/>
                      <MenuItem Header="Rotate right"
                                Command="{Binding RotateCurrentPhotoRightCommand}"
                                IsEnabled="{Binding CanDownloadCurrentPhoto}"/>
                      <MenuItem Header="trash"
                                Command="{Binding MarkCurrentPhotoTrashCommand}"
                                IsVisible="{Binding CanShowCurrentPhotoTrashAction}"
                                IsEnabled="{Binding CanMarkCurrentPhotoTrash}"/>
                      <MenuItem Header="Remove from duplicates"
                                Command="{Binding RemoveCurrentPhotoFromDuplicatesCommand}"
                                IsEnabled="{Binding CanRemoveCurrentPhotoFromDuplicates}"/>
                      <MenuItem Header="Download..."
                                Click="DownloadCurrentPhoto_Click"
                                IsEnabled="{Binding CanDownloadCurrentPhoto}"/>
                    </MenuFlyout>
                  </Button.Flyout>
                </Button>
                <Button Grid.Column="5"
                        Padding="14,10"
                        Command="{Binding ShowNextPhotoInCategoryCommand}"
                        IsEnabled="{Binding CanNavigatePhotoViewerCategory}"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="Black"
                        BorderThickness="2">
                  <Grid>
                    <TextBlock Text="&gt;" FontWeight="SemiBold" Foreground="White" Margin="-1,-1,0,0"/>
                    <TextBlock Text="&gt;" FontWeight="SemiBold" Foreground="White" Margin="1,-1,0,0"/>
                    <TextBlock Text="&gt;" FontWeight="SemiBold" Foreground="White" Margin="-1,1,0,0"/>
                    <TextBlock Text="&gt;" FontWeight="SemiBold" Foreground="White" Margin="1,1,0,0"/>
                    <TextBlock Text="&gt;" FontWeight="SemiBold" Foreground="Black"/>
                  </Grid>
                </Button>
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
